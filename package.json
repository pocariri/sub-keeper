{
  "name": "sub-keeper",
  "version": "0.0.0",
  "private": true,
  "description": "구독 관리 서비스 — 웹 + 모바일 모노레포",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "dev:web": "pnpm --filter @sub-keeper/web dev",
    "dev:mobile": "pnpm --filter @sub-keeper/mobile start",
    "build:web": "pnpm --filter @sub-keeper/web build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "~6.0.3"
  }
}
